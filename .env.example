# FRONTEND (Vite)
VITE_API_URL=http://localhost:4000/api
VITE_CLOUDINARY_CLOUD_NAME=seu-cloud-name
VITE_KEYCLOAK_URL=https://seu-keycloak.com
VITE_KEYCLOAK_REALM=photo-vitoria
VITE_KEYCLOAK_CLIENT_ID=photo-vitoria-admin
VITE_ADMIN_API_URL=https://photo-vitoria-admin-api-rxpgnk6khq-uc.a.run.app
# Por padrão, o site usa assets locais primeiro.
# Para forçar API primeiro (mostrar uploads novos sem redeploy):
# VITE_LOCAL_ASSETS_FIRST=false

# ADMIN GALERIA (GCP Cloud Run)
KEYCLOAK_ISSUER=https://seu-keycloak.com/realms/photo-vitoria
KEYCLOAK_CLIENT_ID=photo-vitoria-admin
# Opcional: lista de roles permitidas, separadas por virgula.
# KEYCLOAK_ALLOWED_ROLES=photo-admin
GITHUB_REPO=elton-peixoto-lu/photo-vitoria
GITHUB_BASE_BRANCH=master
GITHUB_UPLOAD_TOKEN=github_pat_com_acesso_ao_repo

# BACKEND (Express)
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=sua-api-key
CLOUDINARY_API_SECRET=sua-api-secret
PORT=4000
